# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
dist
build
.next
out
*.tsbuildinfo

# Environment files - NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/settings.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Turbo
.turbo

# Test coverage
coverage
.nyc_output

# Supabase
.supabase
supabase/.branches
supabase/.temp

# Docker
*.pem

# Certificates
*.key
*.crt
*.p12

# Secrets
secrets/
*.secret

# Cache
.cache
.parcel-cache
.eslintcache
.stylelintcache

# TypeScript
*.js.map
*.d.ts.map

.vercel

# Playwright MCP snapshots (dev tooling artifacts)
.playwright-mcp/

# Screenshot captures (dev/debugging artifacts)
*.png
*.jpg
*.jpeg
*.gif
*.webp

# ...but real static assets the app ships (favicons, OG/social preview images) must be tracked
!apps/web/public/*.png
!apps/web/public/*.jpg
!apps/web/public/*.jpeg
!apps/web/public/*.webp

# ...and the native app icon/splash asset catalogs Capacitor generates
!apps/web/ios/App/App/Assets.xcassets/**/*.png
!apps/web/android/app/src/main/res/**/*.png
!apps/web/android/app/src/main/res/**/*.webp

.vercel
.env*

# Claude Code local settings — settings.local.json can contain live tokens
# pasted during a session (e.g. VERCEL_TOKEN permission entries)
.claude/settings.local.json

# Capacitor native projects (apps/web/ios, apps/web/android) are committed —
# only their build output/caches are ignored, per Capacitor's own convention.
apps/web/android/.gradle/
apps/web/android/build/
apps/web/android/app/build/
apps/web/android/.idea/
apps/web/android/local.properties
apps/web/android/*.iml
apps/web/android/app/*.iml
apps/web/android/captures/
apps/web/ios/App/Pods/
apps/web/ios/App/build/
apps/web/ios/App/DerivedData/
apps/web/ios/.xcode.env.local
*.keystore
*.p12
*.mobileprovision
