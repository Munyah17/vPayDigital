# =============================================================================
# vPay Environment Configuration
# Copy this file to .env and fill in values — NEVER commit .env to git
# =============================================================================

# --- Node Environment ---
NODE_ENV=development
PORT=3001

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (Direct connection for migrations) ---
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# --- Supabase Access Token (for migrations via Management API) ---
# Get yours at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- VitalPay API (Provider — keep STRICTLY server-side, never expose to client) ---
VITALPAY_SECRET_KEY=your-vitalpay-secret-key
VITALPAY_BASE_URL=https://kmgvitallinks.co.uk/api/v1
VITALPAY_WEBHOOK_SECRET=your-vitalpay-webhook-secret

# --- Provider Configuration ---
PROVIDER_TIMEOUT_MS=30000
PROVIDER_RETRY_ATTEMPTS=3

# --- Frontend URLs ---
WEB_APP_URL=http://localhost:5173
ADMIN_APP_URL=http://localhost:5174
API_URL=http://localhost:3001

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@vpay.app
EMAIL_REPLY_TO=support@vpay.app

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Push Notifications (Firebase) ---
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# --- Redis (for queue/cache) ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Encryption ---
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# --- Webhook ---
WEBHOOK_BASE_URL=https://api.vpay.app
WEBHOOK_RETRY_ATTEMPTS=5

# --- Exchange Rates ---
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_CACHE_TTL_SECONDS=300

# --- Feature Flags ---
FEATURE_CRYPTO_PAYMENTS=false
FEATURE_AMEX_CARDS=false
FEATURE_UNIONPAY_CARDS=false
FEATURE_GIFT_CARDS=true
FEATURE_STREAMING_VOUCHERS=true
FEATURE_GAMING_VOUCHERS=true

# --- Monitoring ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
LOG_LEVEL=info

# --- Vite Frontend (prefix VITE_ for client exposure) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=vPay
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@vpay.app
