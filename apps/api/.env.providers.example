# =============================================================================
# IBAN Provider Configuration
# =============================================================================
# Copy this to .env.local and fill in your provider API credentials

# ─── LORUM (Africa-first, Priority: 1) ────────────────────────────────────
LORUM_ENABLED=true
LORUM_API_KEY=your_lorum_api_key_here
LORUM_BASE_URL=https://sandbox.lorum.com
LORUM_ENVIRONMENT=sandbox
# LORUM_ENVIRONMENT=production  # for production

# ─── CURRENCYCLOUD (Mature Global, Priority: 2) ──────────────────────────
CURRENCYCLOUD_ENABLED=true
CURRENCYCLOUD_API_KEY=your_login_id_here
CURRENCYCLOUD_API_SECRET=your_api_key_here
CURRENCYCLOUD_BASE_URL=https://api-sandbox.currencycloud.com
CURRENCYCLOUD_ENVIRONMENT=sandbox
# CURRENCYCLOUD_BASE_URL=https://api.currencycloud.com  # production

# ─── OPENPAYD (Embedded Finance, Priority: 3) ────────────────────────────
OPENPAYD_ENABLED=true
OPENPAYD_API_KEY=your_openpayd_api_key_here
OPENPAYD_BASE_URL=https://sandbox-api.openpayd.com
OPENPAYD_ENVIRONMENT=sandbox
# OPENPAYD_BASE_URL=https://api.openpayd.com  # production

# ─── AIRWALLEX (Global Fallback, Priority: 4) ────────────────────────────
AIRWALLEX_ENABLED=true
AIRWALLEX_API_KEY=your_airwallex_api_key_here
AIRWALLEX_BASE_URL=https://api-sandbox.airwallex.com
AIRWALLEX_ENVIRONMENT=sandbox
# AIRWALLEX_BASE_URL=https://api.airwallex.com  # production

# =============================================================================
# How to Get Credentials:
# =============================================================================
#
# LORUM:
#   1. Sign up: https://sandbox.lorum.com/register
#   2. Create API key in dashboard
#   3. Copy key to LORUM_API_KEY
#   4. Contact: support@lorum.com for Zimbabwe support confirmation
#
# CURRENCYCLOUD:
#   1. Sign up: https://www.currencycloud.com/register
#   2. Create API credentials in Dashboard
#   3. Copy Login ID to CURRENCYCLOUD_API_KEY
#   4. Copy API Key to CURRENCYCLOUD_API_SECRET
#   5. Verify: https://developer.currencycloud.com/docs/authentication
#
# OPENPAYD:
#   1. Sign up: https://www.openpayd.com
#   2. Request sandbox access
#   3. Get API key from settings
#   4. Copy key to OPENPAYD_API_KEY
#   5. Docs: https://www.openpayd.com/docs
#
# AIRWALLEX:
#   1. Sign up: https://app-sandbox.airwallex.com/register
#   2. Create API key in settings
#   3. Copy key to AIRWALLEX_API_KEY
#   4. Docs: https://www.airwallex.com/docs/api
#
# =============================================================================
